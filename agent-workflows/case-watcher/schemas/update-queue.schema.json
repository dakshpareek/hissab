{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CaseWatcherUpdateQueue",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "queue": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/queueItem"
      },
      "default": []
    }
  },
  "required": ["queue"],
  "definitions": {
    "queueItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal_id": { "type": "string" },
        "case_id": { "type": "string" },
        "score": { "type": "string", "enum": ["high", "medium"] },
        "source_url": { "type": "string" },
        "captured_at": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "done", "held"] },
        "dedupe_key": { "type": "string" }
      },
      "required": ["signal_id", "case_id", "score", "source_url", "captured_at", "status", "dedupe_key"]
    }
  }
}
