{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CaseWatcherState",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "case_registry": { "type": ["array", "null"] },
    "candidate_articles": { "type": "array", "default": [] },
    "scored_signals": { "type": "array", "default": [] },
    "queue_write_result": { "type": ["object", "null"] }
  },
  "required": ["candidate_articles", "scored_signals"]
}
