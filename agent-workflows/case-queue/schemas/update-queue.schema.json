{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SharedCaseUpdateQueue",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "default": 1
    },
    "updated_at": {
      "type": ["string", "null"]
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/queueItem"
      },
      "default": []
    }
  },
  "required": ["version", "items"],
  "definitions": {
    "queueItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal_id": { "type": "string" },
        "case_id": { "type": "string" },
        "score": { "type": "string", "enum": ["high", "medium"] },
        "reason_category": { "type": ["string", "null"] },
        "source_url": { "type": "string" },
        "article_date": { "type": ["string", "null"] },
        "headline_snippet": { "type": ["string", "null"] },
        "captured_at": { "type": ["string", "null"] },
        "dedupe_key": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "done", "held"] },
        "claimed_at": { "type": ["string", "null"] },
        "claimed_by": { "type": ["string", "null"] },
        "processed_at": { "type": ["string", "null"] },
        "held_reason": { "type": ["string", "null"] }
      },
      "required": [
        "signal_id",
        "case_id",
        "score",
        "source_url",
        "dedupe_key",
        "status"
      ]
    }
  }
}
